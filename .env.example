# .env.example — Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.

# ── Seguridad ────────────────────────────────────────────────────
# Genera una clave con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# ── Entorno ──────────────────────────────────────────────────────
# True para desarrollo local. False en producción (Render).
DEBUG=True

# ── Hosts permitidos ─────────────────────────────────────────────
# Desarrollo: localhost,127.0.0.1
# Render:     .onrender.com,tu-app.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos ────────────────────────────────────────────────
# Desarrollo local: dejar vacío → usa SQLite automáticamente.
# Render: provisto por el servicio de base de datos de Render.
# Formato: postgres://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=

# ── Email ────────────────────────────────────────────────────────
# Desarrollo: consola (no envía emails reales)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=biblioteca@demo.com

# Producción: descomentar y completar con datos reales de tu proveedor SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-correo@gmail.com
# EMAIL_HOST_PASSWORD=tu-app-password
